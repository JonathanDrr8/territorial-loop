{
  "name": "territorial-loop",
  "version": "0.6.7",
  "private": true,
  "type": "module",
  "description": "Territorial-RTS Browserspiel mit loopender Spielwelt (Torus-Topologie)",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/server.ts",
    "server": "tsx server/server.ts",
    "deploy": "bash scripts/deploy.sh",
    "feedback": "bash scripts/feedback.sh",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:version": "node scripts/check-version.mjs",
    "format": "prettier --write \"**/*.{ts,js,json,md,html,css}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,html,css}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "seedrandom": "^3.0.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@types/seedrandom": "^3.0.8",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.4.1",
    "prettier": "^3.4.2",
    "tsx": "^4.22.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.7",
    "vitest": "^3.0.2"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,css}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
